# ─── Spring Profile ────────────────────────────────────────────────────────────
# Set to "prod" on Railway. Activates application-prod.yml and reads all
# secrets from environment variables instead of local defaults.
SPRING_PROFILES_ACTIVE=prod

# ─── Server port ───────────────────────────────────────────────────────────────
# Railway injects PORT automatically — do NOT set this in Railway's Variables tab.
# Only needed for local runs that must bind to a specific port.
# PORT=8080

# ─── Database (Railway Postgres plugin injects these automatically) ─────────────
# After adding the Postgres plugin in your Railway project, verify these five
# variables appear under Service → Variables. Do not set them manually if the
# plugin is present — Railway manages them.
PGHOST=containers-us-west-123.railway.app
PGPORT=5432
PGDATABASE=railway
PGUSER=postgres
PGPASSWORD=your-generated-password-here

# ─── Cloudinary (image upload signing) ─────────────────────────────────────────
# Obtain from https://console.cloudinary.com → Dashboard → API Keys.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call the API.
# No trailing slash. No wildcard (*) — credentials require explicit origins.
# Example: https://unishare-frontend.up.railway.app
APP_CORS_ALLOWED_ORIGINS=https://your-frontend.up.railway.app

# ─── Auth / App ────────────────────────────────────────────────────────────────
# Base URL of the frontend — embedded in email links once email is implemented.
APP_AUTH_FRONTEND_BASE_URL=https://your-frontend.up.railway.app

# Email sending mode.
# "log"  → prints emails to the console (safe while email features are stubbed).
# "send" → delivers real emails via SMTP (requires SPRING_MAIL_* vars below).
# NOTE: Change to "send" and configure SPRING_MAIL_* when email features ship.
APP_AUTH_MAIL_MODE=log

# "From" address shown on outgoing emails (used when APP_AUTH_MAIL_MODE=send).
APP_AUTH_MAIL_FROM=no-reply@yourdomain.com

# How long email-verification links remain valid (hours).
APP_AUTH_VERIFICATION_TTL_HOURS=24

# How long password-reset links remain valid (minutes).
APP_AUTH_PASSWORD_RESET_TTL_MINUTES=30

# ─── Mail / SMTP (required only when APP_AUTH_MAIL_MODE=send) ──────────────────
# Uncomment and fill in when email features are implemented.
# SPRING_MAIL_HOST=smtp.gmail.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=you@gmail.com
# SPRING_MAIL_PASSWORD=your-gmail-app-password
