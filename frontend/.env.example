# Copy this file to .env for local development
# For Railway: set VITE_API_URL in the service Variables tab (not in .env)

# Local dev (uses vite proxy so the value is irrelevant for dev, but set it anyway)
VITE_API_URL=http://localhost:8080

# Production (Railway) — replace with your actual backend URL
# VITE_API_URL=https://unishare-production-b5d4.up.railway.app
